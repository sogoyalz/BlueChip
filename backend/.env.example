# Backend environment variables — copy this file to .env and fill in real values.
# Do NOT commit the real .env file.

# MongoDB connection string (e.g. mongodb+srv://<user>:<pass>@<cluster>/<db>)
MONGO_URL=

# Secret used to sign JWT auth tokens (must be >= 32 chars; the app refuses
# to boot with a shorter one).
TOKEN_KEY=

# Set to "production" on the deployed backend. This makes the auth cookie
# secure (HTTPS-only). The cookie is sameSite:"lax" in all environments — in
# production the frontends and API are expected to share ONE registrable domain
# (e.g. www / app / api subdomains) so the cookie is first-party everywhere.
NODE_ENV=

# Optional: port the server listens on (defaults to 3002)
PORT=

# One-shot DESTRUCTIVE data-model migration (drops legacy collections). Only
# runs when set to exactly "true"; leave unset for normal boots. Set it for a
# single deploy if you ever need to re-run the migration, then unset it again.
# RUN_MIGRATIONS=

# Optional: comma-separated allowed browser origins for CORS.
# Defaults to http://localhost:3000,http://localhost:3001 for local dev.
# In production set it to your two deployed frontends, e.g.
# CORS_ORIGINS=https://bluechip-landing.netlify.app,https://bluechip-dash.netlify.app
CORS_ORIGINS=

# Optional rate-limit overrides (sensible defaults built in)
# AUTH_RATE_MAX=20      # login/signup attempts per 15 min per IP
# ORDER_RATE_MAX=30     # orders per minute per user
# MARKET_RATE_MAX=60    # public market-data (candles/book) requests per minute per IP
# GENERAL_RATE_MAX=300  # requests per minute per IP

# Optional: max concurrent SSE price streams per IP (default 5)
# MAX_SSE_PER_IP=5

# Optional: how long (ms) to cache the shared Gemini balances so bursts of
# /api/account and /api/holdings reads don't exhaust Gemini's private-API
# rate budget (default 3000; a fill invalidates the cache immediately).
# GEMINI_BALANCES_TTL_MS=3000

# Optional Gemini endpoint overrides (default to the public production API;
# point at https://api.sandbox.gemini.com / wss://api.sandbox.gemini.com if
# you ever want the sandbox)
# GEMINI_API_URL=
# GEMINI_WS_URL=

# Gemini SANDBOX trading credentials (https://exchange.sandbox.gemini.com/).
# Required to place real (test-fund) orders. One shared key for the whole app.
GEMINI_API_KEY=
GEMINI_API_SECRET=

# Private/trading API base URL. MUST stay pointed at the sandbox — the app
# refuses to boot if this doesn't contain "sandbox". Defaults to
# https://api.sandbox.gemini.com if unset. Never set this to api.gemini.com.
# GEMINI_PRIVATE_API_URL=
